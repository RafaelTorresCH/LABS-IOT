SOILSENSE_SCADA_HOST=192.168.1.50
SOILSENSE_SCADA_PORT=5683
SOILSENSE_SCADA_PATH=sensores
SOILSENSE_SCADA_INTERVAL_S=5

# Use either full IPv6 addresses or RLOC16-derived addressing.
SOILSENSE_SENSOR_ADDR=fd11:22:33:44:0:ff:fe00:7001
SOILSENSE_WATER_ADDR=fd11:22:33:44:0:ff:fe00:7002

# Alternative if you prefer deriving from the OTBR mesh-local prefix.
# SOILSENSE_SENSOR_RLOC16=7001
# SOILSENSE_WATER_RLOC16=7002

# Used only when the water node is temporarily unavailable.
SOILSENSE_LEVEL_FALLBACK=50
